PROJECT_NAME=CodeAtlas

HOST=0.0.0.0

PORT=8000

# Leave DATABASE_URL unset to use backend/data/codeatlas.db safely.
# DATABASE_URL=sqlite:///data/codeatlas.db

VECTOR_DB=data/vectors/

UPLOAD_DIR=uploads/

REPOSITORY_DIR=repositories/

OLLAMA_MODEL=phi3:latest
OLLAMA_BASE_URL=http://localhost:11434
MAX_PROMPT_CHARS=6000

# Structured-first local RAG limits
AI_SOURCE_CHUNK_CHARS=6000
AI_SOURCE_CHUNK_OVERLAP=400
AI_MAX_SOURCE_FILE_BYTES=524288
AI_MAX_CHUNKS_PER_FILE=8
AI_MAX_INDEX_DOCUMENTS=2500

LOG_LEVEL=INFO
